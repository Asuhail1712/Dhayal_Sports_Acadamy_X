PORT=3001

# Enquiry email destination. Change later if needed.
ENQUIRY_TO=asuhail1712@gmail.com

# Preferred enquiry delivery mode.
# Set to "smtp" to force Nodemailer, otherwise Google Apps Script is used.
ENQUIRY_DELIVERY=google-script

# Google Apps Script web app URL for free Gmail-based delivery.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec

# SMTP configuration for Nodemailer.
# For Gmail, use an App Password instead of your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
